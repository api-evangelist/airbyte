  "$id": "https://raw.githubusercontent.com/api-evangelist/airbyte/refs/heads/main/json-schema/airbyte-create-definition-request-schema.json",
  "title": "CreateDefinitionRequest",
  "description": "CreateDefinitionRequest schema from Airbyte API",
  "type": "object",
