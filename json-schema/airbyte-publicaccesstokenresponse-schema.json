{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/PublicAccessTokenResponse",
  "title": "PublicAccessTokenResponse",
  "required": [
    "access_token",
    "token_type",
    "expires_in"
  ],
  "type": "object",
  "properties": {
    "access_token": {
      "type": "string"
    },
    "token_type": {
      "enum": [
        "Bearer"
      ]
    },
    "expires_in": {
      "type": "integer",
      "format": "int64"
    }
  },
  "x-speakeasy-component": true
}