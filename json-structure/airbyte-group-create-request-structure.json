{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/airbyte/refs/heads/main/json-structure/airbyte-group-create-request-structure.json",
  "name": "GroupCreateRequest",
  "description": "Request body for creating a group",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "The name of the group"
    },
    "description": {
      "type": "string",
      "nullable": true,
      "description": "Optional description of the group"
    },
    "organizationId": {
      "type": "uuid",
      "description": "The ID of the organization the group belongs to"
    }
  },
  "required": [
    "name",
    "organizationId"
  ]
}